FROM python:3.12-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    postgresql-client \
    curl \
    # poppler-utils provides pdftoppm/pdftocairo, used by pdf2image to
    # rasterise PDF pages for OpenAI vision input (v2.4.0 line-item
    # extraction). Without it, every PDF extraction job fails at runtime
    # with PDFInfoNotInstalledError.
    poppler-utils \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Release metadata defence-in-depth.
#
# The api container has no .git mount, so the in-process git-describe fallback
# in admin._resolve_current_release_from_git() can't run there. The API instead
# relies on either (a) APP_RELEASE_VERSION being injected via env_file or (b)
# /app/.release.env being readable on disk.
#
# Both paths are fragile:
#   - env_file long-form `path: required: false` is silently skipped by
#     Compose < 2.24
#   - .release.env is gitignored and only generated by
#     scripts/update_release_metadata.sh, so a fresh checkout that builds
#     before that script runs ends up with an empty file in the build context
#
# This RUN step closes the gap: if COPY didn't bring a populated .release.env,
# we synthesise one from build args (preferred when a caller like
# safe_update.sh forwards them) or from a self-describing marker (worst case,
# so operators see WHY the metadata is missing instead of a silent "nicht
# gesetzt" in the UI).
ARG APP_RELEASE_VERSION=""
ARG APP_RELEASE_COMMIT=""
RUN if [ ! -s /app/.release.env ] || ! grep -qE "^APP_RELEASE_VERSION=.+" /app/.release.env; then \
      printf '# Generated by Dockerfile (no populated .release.env in build context)\nAPP_RELEASE_VERSION=%s\nAPP_RELEASE_COMMIT=%s\n' \
        "${APP_RELEASE_VERSION:-image-build-no-metadata}" \
        "${APP_RELEASE_COMMIT}" > /app/.release.env; \
    fi

EXPOSE 8000
CMD ["sh", "-c", "alembic upgrade head && uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers ${API_WORKERS:-2} --timeout-keep-alive 75"]
