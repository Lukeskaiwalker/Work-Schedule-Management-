# Passphrase used to encrypt/decrypt backups in scripts/backup.sh and
# scripts/restore.sh. Forwarded to the update_runner container by
# docker-compose.yml. Generate a long random value (e.g. `openssl rand -base64 48`)
# and store it in your secret manager — losing this means the backups are
# unrecoverable. As an alternative, set BACKUP_PASSPHRASE_FILE to the path of a
# file mounted into the runner container holding the same value.
BACKUP_PASSPHRASE=
BACKUP_PASSPHRASE_FILE=
